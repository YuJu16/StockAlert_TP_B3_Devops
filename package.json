{
  "name": "stockalert-api",
  "version": "1.0.0",
  "description": "API de gestion d'alertes de stock — TP CI/CD DevOps B3",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "test": "node app.test.js",
    "lint": "eslint app.js app.test.js"
  },
  "eslintConfig": {
    "env": { "node": true, "es2021": true },
    "rules": {
      "no-unused-vars": "error",
      "semi": ["error", "always"],
      "quotes": ["error", "double"]
    }
  },
  "devDependencies": {
    "eslint": "^8.0.0"
  }
}
